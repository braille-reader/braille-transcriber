ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec

# Android
*.iml
.gradle
local.properties
.idea/workspace.xml
.idea/libraries
.idea/caches
.idea/modules.xml
android/.gradle/
android/captures/
