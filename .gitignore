# Braille OCR Transcriber - .gitignore

# External repos (cloned as dependencies)
DotNeuralNet/

# Training data sources (large / restricted access — see data/README.md)
data/brf/
data/gutenberg/
data/synthetic/

# Local config (contains API keys / local paths)
.mcp.json
.claude/

.DS_Store
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
ENV/
env/
.venv

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb

# PyTorch
*.pth
*.pt
*.ckpt

# TensorFlow
*.h5
*.pb
saved_model/

# Models & Weights (too large for git)
models/*.pt
models/*.pth
models/*.h5
weights/
checkpoints/

# Data
data/raw/
data/processed/
datasets/*/images/
datasets/*/annotations/
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff

# Keep dataset structure but not images
!data/.gitkeep
!datasets/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
tensorboard/
wandb/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Environment
.env
.env.local
secrets/
*.key
*.pem

# Mobile Development
# Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
flutter_*.log

